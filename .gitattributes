# Normalize line endings to LF for text files (avoids cross-OS noise diffs)
* text=auto eol=lf

# Explicit binary types — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.svg  text eol=lf
*.ico  binary
*.mp3  binary
*.mp4  binary
*.m4a  binary
*.pdf  binary
*.zip  binary
